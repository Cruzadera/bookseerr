{
  "name": "bookseerr",
  "version": "1.0.0",
  "description": "Servicio fullstack para buscar, descargar e importar ebooks con Prowlarr, qBittorrent y Calibre-Web.",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "build": "vite build --config frontend/vite.config.cjs",
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "dev:api": "nodemon src/server.js",
    "dev:web": "vite --config frontend/vite.config.cjs"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "axios": "^1.9.0",
    "axios-cookiejar-support": "^6.0.4",
    "cheerio": "^1.0.0",
    "chokidar": "^4.0.3",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "form-data": "^4.0.5",
    "i18next": "^26.0.4",
    "i18next-fs-backend": "^2.6.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tough-cookie": "^5.1.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "nodemon": "^3.1.10",
    "vite": "^8.0.8"
  }
}
